{
  "manifest_version": 3,
  "key": "",
  "name": "StackNest — Tab Manager",
  "version": "1.0.0",
  "description": "A calm command center for your tabs and bookmarks, on every new tab. Group open tabs, stash them into folders, and curate your library without clutter.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "js/sw.js"
  },
  "incognito": "spanning",
  "permissions": ["tabs", "bookmarks", "favicon", "storage", "identity", "notifications", "alarms"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://api.coingecko.com/*",
    "https://open.er-api.com/*"
  ],
  "oauth2": {
    "client_id": "599136003782-49rr17vnbjhf2a8acgd3ftlmi17oqtb0.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
